# =============================================
# LiteLLM — Chat Completion (provided by TA)
# =============================================
LITELLM_API_KEY=your_api_key_here
LITELLM_BASE_URL=https://your-litellm-endpoint/

# =============================================
# LLM Model (default)
# =============================================
DEFAULT_LLM_MODEL=gemini-2.5-flash

# =============================================
# Embedding Model (local, free — no key needed)
# sentence-transformers runs fully offline.
# First run downloads ~80MB model automatically.
# =============================================
EMBEDDING_MODEL=all-MiniLM-L6-v2

# =============================================
# ChromaDB — local persistent vector store
# No server required. Data stored in this dir.
# =============================================
CHROMA_PERSIST_DIR=./chroma_db
